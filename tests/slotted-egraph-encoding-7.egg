; A brutally simple slotted implementation that is not super efficient.
; The inefficiency comes from the fact that every node has *multiple* shapes depending on what variant of the children was chosen.

(sort Renaming (Map i64 i64))
(sort VecOfRenaming (Vec Renaming))

(sort U) ; includes terms, ids, nodes.
(sort P)

(constructor Var (i64) U)
(constructor App (String U U) U)
(constructor Rename (Renaming U) U)

(constructor Project (U) P)
(function ProjectLeader (P) U :merge (ordering-min old new))

; f(x, y) = [a -> x, b -> y] * f(a, b)
; Project f(x, y) = Project f(a, b)
; Project x = { m*x | renaming m }
; f(a) = [x -> a] * f(x)
; [x -> b] * f(x)

(rule
    ((= (Rename _ a) b))
    (
        (set (ProjectLeader (Project a)) a)
        (set (ProjectLeader (Project b)) b)
        (union (Project a) (Project b))
    )
)

; For every leader a, and every b that is equal up to renaming to a,
; i.e. m*b = a,
; we want to compute the normal form of b, which *has* to include the leader.
; Thus the normal form of b is m⁻¹*a.

; Rename inverse
(rule
    (
        (= a (Rename m b))
        (= a (ProjectLeader (Project a)))
    )
    ((union b (Rename (inverse m) a)))
)

; collapse nested renames towards leaders.
; Think: a -> m*b, where b is the leader (for now).
; But later we notice b -> m'*c (where c is the new leader, instead of b).
; Then we want a new normal form for a, which is a -> m*m'*c.

; Rename compose
(rule
    (
        (= x (Rename m1 (Rename m2 y)))
        (= y (ProjectLeader (Project y)))
    )
    ((union x (Rename (compose m1 m2) y)))
)

; shape computation for Var
(rule
    ((Var n))
    ((union (Var n) (Rename (map-insert (map-empty) 0 n) (Var 0))))
)


;; (App f (Rename ... (Var 3)) (Rename ... (Var 0)))

; shape computation for App
(rule 
    (
        (= x (App f (Rename m1 a1) (Rename m2 a2)))
        (= a1 (ProjectLeader (Project a1)))
        (= a2 (ProjectLeader (Project a2)))
        (= m_sh (shape2 m1 m2))
        ; m_sh :: slots(x) -> shape-slots
    )
    (
        (union x
           (Rename (inverse m_sh)
              (App f
                (Rename (compose m_sh m1) a1) (Rename (compose m_sh m2) a2))))
    )
)

(rule
    ((= x (App _f _x _y)))
    ((set (ProjectLeader (Project x)) x))
)

(rule
    ((= x (Var _v)))
    ((set (ProjectLeader (Project x)) x))
)

(let $v1 (Var 24))
(let $v2 (Var 12))
(let $v3 (Var 3))
(let $v4 (Var 4))

(let $fv1v2 (App "f" $v1 $v2))
(let $y (App "f" $v3 $v4))

(let $gxv2 (App "g" $fv1v2 $v2))
(let $y2 (App "g" $y $v4))


;; a rule that drops the first argument for "id"
(rule ((= lhs (App "id" (Rename m x) (Rename m2 x2)))
       (= x (ProjectLeader (Project x)))
       (= x2 (ProjectLeader (Project x2)))
       )
      ((union lhs (Rename m x))))

(let $idapp (App "id" $v1 $v1))


;; a complex rule
(rule ((= lhs (App "Add"
                  (App "Add" a b)
                  b)))
      ((union lhs (App "Add" a (App "Add" b b))))
      :name "userassocweird")


(let $t1 (App "Add" (App "Add" (Var 0) (Var 2)) (Var 2))) 
(let $t2 (App "Add" (Var 2) (App "Add" (Var 0) (Var 0))))
(let $t3 (App "Add" (Var 2) (App "Add" (Var 0) (Var 3))))

(run 1000)

; (print-function Rename)
; (print-function ProjectLeader)

; Here we check equality up to renaming!
(check (= (Project $v1) (Project $v4)))
(check (= (Project $gxv2) (Project $y2)))

(check (= $idapp $v1))
(check (= (Project $idapp) (Project $v2)))

(check (= (Project $t1) (Project $t2)))
(check (!= (Project $t1) (Project $t3)))

(print-size)


