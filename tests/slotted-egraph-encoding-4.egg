; slotted unionfind

;; sorts & constructors.

(sort NameMap (Map i64 i64))
(sort VecOfNameMap (Vec NameMap))
(sort Id)
(sort AppliedId)

(constructor MkAppliedId (NameMap Id) AppliedId)

;;; UNIONFIND
(relation Unionfind (Id AppliedId))
(relation Union (AppliedId AppliedId))
(function Find (AppliedId) AppliedId :merge new)

;;; Puts a new AppliedId in the unionfind as a leader.
(rule
    (
        (MkAppliedId m i)
        ; i :: X
        ; m :: X -> Y
        ; m⁻¹ * m :: X -> X
    )
    (
        (Unionfind i (MkAppliedId (compose m (invert m)) i))
    )
)

; path compression
(rule
    (
        (Unionfind i1 (MkAppliedId m1 i2))
        (Unionfind i2 (MkAppliedId m2 i3))
        (!= i2 i3)
    )
    (
        (delete (Unionfind i1 (MkAppliedId m1 i2)))
        (Unionfind i1 (MkAppliedId (compose m2 m1) i3))
    )
)

; union symmetry
(rule
    ((Union x1 x2))
    ((Union x2 x1))
)

(rule
    (
        (Union x1 x2)
        (= (Find x1) (MkAppliedId m1 a1))
        (= (Find x2) (MkAppliedId m2 a2))
        (!= a1 a2)
        (= a2 (ordering-max a1 a2)) ; a2 -> a1
    )
    (
        ; m1*a1 = m2*a2
        ; a2 = m2⁻¹*m1*a1
        ; a2 = (compose m1 (invert m2)) * a1
        (Unionfind a2 (MkAppliedId (compose m1 (invert m2)) a1))
    )
)

; implementation of find based on the unionfind.
(rule
    (
        (MkAppliedId m1 i)
        (Unionfind i (MkAppliedId m2 j))
    )

    (
        (set (Find (MkAppliedId m1 i)) (MkAppliedId (compose m2 m1) j))
    )
)

; unionfind CPs
(rule
    (
        (= x1 (MkAppliedId m1 a1))
        (= x2 (MkAppliedId m2 a2))
        (Unionfind i x1)
        (Unionfind i x2)
        (!= x1 x2)
        (= a2 (ordering-max a1 a2)) ; x2 -> x1
    )

    (
        (Union x1 x2)
        (delete (Unionfind i x2))
    )
)



; EXAMPLE:
(constructor A () Id) ; :: [0]
(constructor B () Id) ; :: [1]
(constructor C () Id) ; :: [2]

(let $m00 (map-insert (map-empty) 0 0))
(let $m11 (map-insert (map-empty) 1 1))

(let $m13 (map-insert (map-empty) 1 3))
(let $m03 (map-insert (map-empty) 0 3))

(let $m07 (map-insert (map-empty) 0 7))
(let $m27 (map-insert (map-empty) 2 7))

(Union (MkAppliedId $m03 (A)) (MkAppliedId $m13 (B)))
(Union (MkAppliedId $m07 (A)) (MkAppliedId $m27 (C)))

(run 10)

(print-function Unionfind)
(print-function Find)
