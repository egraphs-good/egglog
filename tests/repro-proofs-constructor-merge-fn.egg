;; tests that merge function with constructor saturates correctly
(sort Math)

(constructor MyGt (Math Math) Math)
(constructor Num (i64) Math)

(function Biggie (i64) Math :merge (MyGt old new))


(rule ()
      ((set (Biggie 1) (Num 1))
       (set (Biggie 2) (Num 2))
       (set (Biggie 3) (Num 3))))

(run 1)

(rewrite (MyGt (Num a) (Num b)) (Num (max a b)))

(run 2)

(check (= (Biggie 3) a)
       (= a (Num 3)))
