;    (EqualWithRename sub1 (AppId m2 (App2 "+" a b)))
; ))

(push)

(let $x (Var 0))
(let $y (Var 1))

(run 10)

(check (EqualWithRename $x (AppId some-rename $y)))

(print-function EqualWithRename)

(pop)

(push)

(let $identity0 (map-insert (map-empty) 0 0))
(let $identity1 (map-insert (map-empty) 1 1))


(let $x (AppId $identity0 (Var 0)))
(let $y (AppId $identity1 (Var 1)))

; add f(x, y), f(y, x)
; hopefully they are represented by the same e-class.
(let $fxy (App2 "f" $x $y))
(let $fyx (App2 "f" $y $x))

(run 10)

(print-function EqualWithRename)
(check (EqualWithRename $fxy (AppId some-rename $fyx)))

(pop)


