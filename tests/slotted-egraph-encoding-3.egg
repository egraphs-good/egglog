;     (= b (App2 f (AppId m_b1 ch_b1) (AppId m_b2 ch_b2)))
;     (EqualWithRename ch_b1 (AppId m2 ch_a1))
;     (EqualWithRename ch_b2 (AppId m1 ch_a2)))
;     ; ch_b1 = m2 * ch_a1
;     ; ch_b2 = m1 * ch_a2
;     (EqualWithRename a (AppId ? b))
;)

