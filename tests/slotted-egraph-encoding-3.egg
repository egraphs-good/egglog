

(sort NameMap (Map i64 i64))
(sort VecOfNameMap (Vec NameMap))
(sort Expr)

;; A variable has a name as an i64
(constructor Var (i64) Expr)


(sort AppliedId)
(constructor AppId (NameMap Expr) AppliedId)

(constructor App2 (String AppliedId AppliedId) Expr)
; (constructor App2View (String AppliedId AppliedId) Expr)

;; this is the union-find
(relation EqualWithRename (Expr AppliedId))


(relation ShapeOf (Expr NameMap Expr))


; shape computation of var
(rule ((Var n))
      ((ShapeOf (Var n) (map-insert (map-empty) 0 n) (Var 0))))


; shape computation of App2
(rule ((= lhs (App2 f (AppId m1 c1) (AppId m2 c2))))
      ((let tuple (shape m1 m2))
       (let m1_p (vec-get tuple 0))
       (let m2_p (vec-get tuple 1))
       (let shape-to-original (vec-get tuple 2))
       (ShapeOf lhs shape-to-original (App2 f (AppId m1_p c1) (AppId m2_p c2)))))


; equal shape? -> merge in unionfind. congruence.
(rule ((ShapeOf e1 mapping1 shape)
       (ShapeOf e2 mapping2 shape)
      (= e1 (ordering-max e1 e2))
      (!= e1 e2)
      )
     ((EqualWithRename e1 (AppId (compose (invert mapping2) mapping1) e2))))

; path compression in the UF
(rule (
    (EqualWithRename a (AppId m1 b))
    (EqualWithRename b (AppId m2 c))
    (= b (ordering-max b c))
    (!= b c)
    )
    ; a = m1*b
    ; b = m2*c
    ; a = m1*m2 * c
    (
    (delete (EqualWithRename a (AppId m1 b)))
    (EqualWithRename a (AppId (compose m2 m1) c))
    )
)

; resolving multiple parents in the UF.
(rule ((EqualWithRename a (AppId m1 b))
      (EqualWithRename a (AppId m2 c))
      (!= b c)
      (= (ordering-max b c) b)
      )
      ((delete (EqualWithRename a (AppId m1 b)))
      ; a = m1 * b
      ; a = m2 * c
      ; m1 * b = m2 * c
      ; -> b = (m1⁻¹ * m2) * c
      (EqualWithRename b (AppId (compose (invert m1) m2) c))
      )
)


; rebuilding left.
(rule (
    (= a (App2 f (AppId m_a1 ch_a1) rhs))
    (EqualWithRename ch_a1 (AppId m i))
    )
    ; ch_a1 = m * i
    ; -> m_a1 * ch_a1 = (m_a1 * m) * i
    ; -> m_a1 * ch_a1 = (compose m m_a1) * i
    ((App2 f (AppId (compose m m_a1) i) rhs))
)

; rebuilding right.
(rule (
    (= a (App2 f lhs (AppId m_a2 ch_a2)))
    (EqualWithRename ch_a2 (AppId m i))
    )
    ; ch_a2 = m * i
    ; -> m_a2 * ch_a2 = (m_a2 * m) * i
    ; -> m_a2 * ch_a2 = (compose m m_a2) * i
    ((App2 f lhs (AppId (compose m m_a2) i)))
)

; user writes:
; (rule (App2 "*" (App2 "+" a b) c)))

; we generate:
; (rule (
;    (App2 "*" (AppId m1 sub1) c)
;    (EqualWithRename sub1 (AppId m2 (App2 "+" a b)))
; ))


; Tests:

(push)

(let $x (Var 0))
(let $y (Var 1))

(run 10)

(check (EqualWithRename $y (AppId some-rename $x)))

(print-function ShapeOf)
(print-function EqualWithRename)

(pop)

(push)

(let $identity0 (map-insert (map-empty) 0 0))
(let $identity1 (map-insert (map-empty) 1 1))

(let $x (AppId $identity0 (Var 0)))
(let $y (AppId $identity1 (Var 1)))

; add f(x, y), f(y, x)
; hopefully they are represented by the same e-class.
(let $fxy (App2 "f" $x $y))
(let $fyx (App2 "f" $y $x))

(run 30)

(check (EqualWithRename $fxy (AppId _ $fxy)))
(check (EqualWithRename $fyx (AppId _ $fxy)))

(print-function EqualWithRename)
(print-function ShapeOf)

(pop)


