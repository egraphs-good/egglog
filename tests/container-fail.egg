;; https://github.com/egraphs-good/egglog/issues/831
(sort E)
(sort F (UnstableFn () E))
(sort VE (Vec E))

(constructor b () E)
(constructor k (E) E)
(constructor w (E) E)
(constructor l (VE) E)
(constructor m () E)

(rewrite (w x) x)
(rewrite (m)
  (l (vec-of (w (k (b))))))
(rewrite (l (vec-of (k x)))
  x)

(let $from-unstable (unstable-app (unstable-fn "m")))
(run-schedule (saturate (run)))
(check (= $from-unstable (b))))
