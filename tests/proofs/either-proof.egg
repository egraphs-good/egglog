(sort Math)
(constructor A () Math)
(constructor B () Math)

(sort MathOrInt (Either Math i64))
(datatype EitherBox (Box MathOrInt))

(let left-a-box (Box (either-left (A))))
(let right-int-box (Box (either-right 7)))

(function boxed-left (EitherBox) Math :merge old)
(function boxed-right (EitherBox) i64 :merge old)
(rule ((= box (Box value))
       (= left (either-unwrap-left value)))
      ((set (boxed-left box) left))
      :name "project-left")
(rule ((= box (Box value))
       (= right (either-unwrap-right value)))
      ((set (boxed-right box) right))
      :name "project-right")
(run 1)
(prove (= (boxed-left left-a-box) (A)))
(prove (= (boxed-right right-int-box) 7))

(union (A) (B))
(prove (= left-a-box (Box (either-left (B)))))
(prove (= (boxed-left left-a-box) (B)))
