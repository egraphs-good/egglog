; Test that primitives can have other primitives as arguments,
; but constructor/function calls get extracted

(datatype Math
  (Const i64)
  (Add Math Math)
  (Mul Math Math))

(relation MathU (Math))

; This rule has a primitive (>) with another primitive (+) as an argument
; Both should be allowed since primitives can have primitives as args
(rule ((MathU (Const a))
       (> (+ a 1) 5))
      ((MathU (Add (Const a) (Const 1)))))

; This rule has a primitive (!=) with a constructor (Const) as an argument
; The Const should get extracted into a separate fact
; Changed condition to > 0 so it will fire for 5
(rule ((MathU (Const a))
       (> a 0))
      ((MathU (Mul (Const a) (Const 1)))))

(MathU (Const 5))
(run 3)

; Check that the rules fired
(prove (MathU (Add (Const 5) (Const 1))))
(prove (MathU (Mul (Const 5) (Const 1))))

