(datatype IntPair (Pair i64 i64))
(datatype PairBox (Box IntPair))

(let boxed (Box (Pair 1 2)))
(prove (= boxed (Box (Pair 1 2))))

(function boxed-first (PairBox) i64 :merge old)
(function boxed-second (PairBox) i64 :merge old)
(rule ((= box (Box (Pair first second))))
      ((set (boxed-first box) first)
       (set (boxed-second box) second))
      :name "project-userland-pair")
(run 1)
(prove (= (boxed-first boxed) 1))
(prove (= (boxed-second boxed) 2))

(sort Math)
(constructor A () Math)
(constructor B () Math)
(datatype MathPair (MPair Math i64))
(datatype MathPairBox (MathBox MathPair))
(datatype IntMathPair (RPair i64 Math))
(datatype IntMathPairBox (RightMathBox IntMathPair))

(let math-boxed (MathBox (MPair (A) 42)))
(let right-math-boxed (RightMathBox (RPair 42 (A))))
(prove (= math-boxed (MathBox (MPair (A) 42))))

(union (A) (B))
(prove (= math-boxed (MathBox (MPair (B) 42))))
(prove (= right-math-boxed (RightMathBox (RPair 42 (B)))))
