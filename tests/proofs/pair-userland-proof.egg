(sort Math)
(constructor A () Math)
(constructor B () Math)
(datatype MathIntPair (Pair Math i64))
(datatype MathIntPairBox (Box MathIntPair))

(let boxed (Box (Pair (A) 2)))

(function boxed-first (MathIntPairBox) Math :merge old)
(function boxed-second (MathIntPairBox) i64 :merge old)
(rule ((= box (Box (Pair first second))))
      ((set (boxed-first box) first)
       (set (boxed-second box) second))
      :name "project-userland-pair")
(run 1)
(prove (= (boxed-first boxed) (A)))
(prove (= (boxed-second boxed) 2))

(union (A) (B))
(prove (= boxed (Box (Pair (B) 2))))
(prove (= (boxed-first boxed) (B)))
