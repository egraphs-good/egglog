(sort Math)
(constructor A () Math)
(constructor B () Math)
(sort MathIntPair (Pair Math i64))
(datatype MathIntPairBox (Box MathIntPair))
(sort IntMathPair (Pair i64 Math))
(datatype IntMathPairBox (RightBox IntMathPair))

(let boxed (Box (pair (A) 2)))
(let right-boxed (RightBox (pair 2 (A))))

(function boxed-first (MathIntPairBox) Math :merge old)
(function boxed-second (MathIntPairBox) i64 :merge old)
(rule ((= box (Box p)))
      ((set (boxed-first box) (pair-first p))
       (set (boxed-second box) (pair-second p)))
       :name "project")
(run 1)
(prove (= (boxed-first boxed) (A)))
(prove (= (boxed-second boxed) 2))

(union (A) (B))
(prove (= boxed (Box (pair (B) 2))))
(prove (= right-boxed (RightBox (pair 2 (B)))))
(prove (= (boxed-first boxed) (B)))
