
(datatype Math
  (Add i64 i64)
  (Num i64))

;; Commutativity
(rule ((Add a b)) ((union (Add a b) (Add b a))) :name "rw1")

;; Constant folding with an extra condition, forcing commute first
(rule ((Add a b)
       (> a b))
      ((union (Add a b) (Num (+ a b)))) :name "rw2")


(let start (Add 2 3))

(run 2)

(prove (= (Add 2 3) (Num 5)))