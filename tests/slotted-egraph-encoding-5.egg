(sort Renaming (Map i64 i64))
(sort VecOfRenaming (Vec Renaming))

(sort U) ; includes terms, ids, nodes.

; NF (a m b) means a -> m*b
(relation NF (U Renaming U))

(constructor Var (i64) U)
(constructor App (String U U) U)
(constructor Rename (Renaming U) U)

; NF for Var
(rule
    ((Var n))
    ((NF (Var n) (map-insert (map-empty) 0 n) (Var 0)))
)

; NF for Rename (is this necessary to have?)
(rule
    (
        (= x (Rename m1 y))
        (NF y m2 z)
    )
    ; x = m1*y; y = m2*z; -> x=m1*m2*z
    
    (
        (NF x (compose m1 m2) z)
    )
)

; NF for App
(rule 
    (
        (= x (App f t1 t2))
        (NF t1 m1 a1)
        (NF t2 m2 a2)
        (= m_sh (shape2 m1 m2))
        ; m_sh :: slots(x) -> shape-slots
    )
    (
        (NF x (inverse m_sh) (App f (Rename (compose m_sh m1) a1) (Rename (compose m_sh m2) a2)))
    )
)

; handle critical pairs in NF.
(rule
    (
        (NF lhs m1 a1)
        (NF lhs m2 a2)
        (!= a1 a2) ; TODO: fix redundancy
        (= (ordering-max a1 a2) a2) ; a2 -> a1
    )
    (
        ; m2*a2 = m1*a1
        ; -> a2 = m2⁻¹*m1*a1
        (delete (NF lhs m2 a2))
        (NF a2 (compose (inverse m2) m1) a1)
    )
)

; path compression in NF.
(rule
    (
        (NF a m1 b)
        (NF b m2 c)
        (= b (ordering-max b c))
    )

    (
        (NF a (compose m1 m2) c)
    )
)

(let $v1 (Var 24))
(let $v2 (Var 12))
(let $v3 (Var 3))
(let $v4 (Var 4))

(let $x (App "f" $v1 $v2))
(let $y (App "f" $v3 $v4))

(let $x2 (App "g" $x $v2))
(let $y2 (App "g" $y $v4))

(run 100)

; Here we check equality up to renaming!
(check (NF $v1 _ a) (NF $v4 _ a))
(check (NF $x _ a) (NF $y _ a))
(check (NF $x2 _ a) (NF $y2 _ a))

(print-function NF)
