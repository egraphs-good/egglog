      ((HasArgType lhs ty))
        :ruleset type-analysis :name "(rule ((= lhs (If c i t e))
       (HasArgType c ty))
      ((HasArgType lhs ty))
        :ruleset type-analysis )")
(rule ((= lhs (If c i t e))
       (HasType i ty)
       (HasArgType t ty2)
       (!= ty ty2))
      ((panic "if branches then branch has incorrect input type"))
        :ruleset error-checking :name "(rule ((= lhs (If c i t e))
       (HasType i ty)
